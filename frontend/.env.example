# Copy to .env and fill in. NEVER commit .env.
# Uses the shared Frula (fsbo-platform) Supabase project; app data lives in the
# `chore` schema.

# Frula Supabase project settings → API
SUPABASE_URL=https://your-frula-project-ref.supabase.co
SUPABASE_KEY=your-anon-key

# NestJS API base URL
API_BASE=http://localhost:3000
