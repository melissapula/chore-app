# Copy to .env and fill in. NEVER commit .env.
# Uses the shared Frula (fsbo-platform) Supabase project — app tables live in
# the `chore` schema, isolated from Frula's public tables.
PORT=3000

# Frula Supabase project settings → API
SUPABASE_URL=https://your-frula-project-ref.supabase.co

# anon/public key — used for user-scoped (JWT) clients so RLS applies
SUPABASE_ANON_KEY=your-anon-key

# service_role key — bypasses RLS. ONLY for trusted server jobs
# (the cron timer sweep, parent-creates-kid onboarding). Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend origin allowed to call this API (CORS)
FRONTEND_ORIGIN=http://localhost:3001
