# Copy to .env and fill in. NEVER commit .env.
PORT=3000

# Supabase project settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — used for user-scoped (JWT) clients so RLS applies
SUPABASE_ANON_KEY=your-anon-key

# service_role key — bypasses RLS. ONLY for trusted server jobs
# (the cron timer sweep, parent-creates-kid onboarding). Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend origin allowed to call this API (CORS)
FRONTEND_ORIGIN=http://localhost:3001
